# =============================================================================
# .gitignore：指定哪些文件/目录不应该被 Git 跟踪
# =============================================================================

# Java / Maven 构建产物
backend/target/
backend/*.iml

# Node.js / 前端依赖和构建产物
frontend/node_modules/
frontend/dist/
frontend/.umi/
frontend/.umi-production/
frontend/src/.umi/
frontend/src/.umi-production/
frontend/package-lock.json
frontend/pnpm-lock.yaml
frontend/yarn.lock

# Nginx 日志、临时文件和二进制
# 由于已使用系统 Nginx，便携版二进制不再提交
nginx/logs/
nginx/tmp/
nginx/pkg/
# Windows 平台自动生成的配置文件（由模板生成，包含机器相关绝对路径）
nginx/nginx-win.conf
nginx/conf.d/default-win.conf

# Windows 平台便携工具（JDK / Maven / Nginx）
tools/

# Tomcat 日志、临时文件和运行数据
tomcat/logs/
tomcat/temp/
tomcat/work/
tomcat/webapps/backend/
# 保留 WAR 包示例，如果不需要可取消下面注释
# tomcat/webapps/backend.war

# 开发脚本运行时生成的日志
backend-dev.log
backend-dev.err.log
frontend-dev.log
run-dev.log

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
