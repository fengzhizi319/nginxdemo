# =============================================================================
# .gitignore：指定哪些文件/目录不应该被 Git 跟踪
# =============================================================================

# Java / Maven 构建产物
backend/target/
backend/*.iml

# Node.js / 前端依赖和构建产物
frontend/node_modules/
frontend/dist/
frontend/.umi/
frontend/.umi-production/
frontend/package-lock.json
frontend/pnpm-lock.yaml
frontend/yarn.lock

# Nginx 日志、临时文件和二进制（如果希望二进制不被提交，可取消下面注释）
nginx/logs/
nginx/tmp/
# nginx/pkg/

# Tomcat 日志、临时文件和运行数据
tomcat/logs/
tomcat/temp/
tomcat/work/
tomcat/webapps/backend/
# 保留 WAR 包示例，如果不需要可取消下面注释
# tomcat/webapps/backend.war

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
